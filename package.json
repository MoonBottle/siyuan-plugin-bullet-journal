{
  "name": "siyuan-plugin-bullet-journal",
  "version": "0.12.8",
  "type": "module",
  "description": "Task Assistant plugin for SiYuan (https://b3log.org/siyuan)",
  "author": "",
  "license": "AGPL-3.0",
  "homepage": "",
  "repository": "",
  "scripts": {
    "dev": "vite build --config vite.mcp.config.ts && concurrently \"vite build --config vite.mcp.config.ts -w\" \"vite build -w\"",
    "release": "node ./release.js",
    "release:manual": "node ./release.js --mode=manual",
    "release:patch": "node ./release.js --mode=patch",
    "release:minor": "node ./release.js --mode=minor",
    "release:major": "node ./release.js --mode=major",
    "build": "vite build --config vite.mcp.config.ts && cross-env EMPTY_OUT_DIR=false vite build",
    "mcp": "node dist/mcp-server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.17",
    "@fullcalendar/daygrid": "^6.1.17",
    "@fullcalendar/interaction": "^6.1.17",
    "@fullcalendar/list": "^6.1.17",
    "@fullcalendar/timegrid": "^6.1.17",
    "@tencent-weixin/openclaw-weixin": "^2.1.1",
    "chart.js": "^4.5.1",
    "croner": "^10.0.1",
    "dayjs": "^1.11.20",
    "dhtmlx-gantt": "^9.1.3",
    "grid-layout-plus": "^1.1.1",
    "pinia": "^3.0.2",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/node": "^22.13.11",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-perfectionist": "^5.7.0",
    "fast-glob": "^3.3.3",
    "glob": "^13.0.6",
    "happy-dom": "^20.9.0",
    "minimist": "^1.2.8",
    "rollup-plugin-livereload": "^2.0.5",
    "sass": "^1.98.0",
    "siyuan": "1.1.8",
    "typescript": "^5.8.2",
    "vite": "^8.0.1",
    "vite-plugin-remove-console": "^2.2.0",
    "vite-plugin-static-copy": "^3.2.6",
    "vite-plugin-zip-pack": "^1.0.6",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  }
}
